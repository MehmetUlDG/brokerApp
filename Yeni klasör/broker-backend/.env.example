# ─────────────────────────────────────────────────────────────────────────────
# Demo Broker Backend — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Bu dosyayı .env.local olarak kopyalayın ve değerleri güncelleyin.
# GIT'E KESİNLİKLE YÜKLEME → .gitignore içine ekleyin!

# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development
HTTP_PORT=3000
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=broker_user
DB_PASSWORD=broker_secret
DB_NAME=broker_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=broker-consumer-group
KAFKA_TOPIC_ORDERS=broker.orders
KAFKA_TOPIC_TRADES=broker.trades

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=super_secret_change_this_in_production
JWT_EXPIRY=24h

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=json
